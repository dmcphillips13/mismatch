# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
**/.next/
/out/
**/out/

# production
/build

# misc
.claude
.DS_Store
*.pem
AGENTS.md
PROJECT_CONTEXT.md

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.pnpm-store/
**/.pnpm-store/

# env files (can opt-in for committing if needed)
.env*
!.env.example
!**/.env.example

# python
.venv/
**/.venv/
__pycache__/
**/__pycache__/
*.pyc

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
